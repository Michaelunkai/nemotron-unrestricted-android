#!/data/data/com.termux/files/usr/bin/python
"""Project-local Android control with verified semantic actions and shared guards."""

from __future__ import annotations

import hashlib
import json
import pathlib
import re
import shlex
import subprocess
import sys
import time
import urllib.parse
import xml.etree.ElementTree as ET

from nemotron_android_policy import (
    AndroidBridgeError,
    AndroidPolicyError,
    PROTECTED_PACKAGES,
    list_packages,
    package_evidence,
    package_is_protected,
    run_rish,
    sanitized_policy_message,
    validate_android_shell_command,
    validate_package_id,
    verify_png_file,
)


COMPONENT_RE = re.compile(r"\bu\d+\s+([^\s}]+/[^\s}]+)")
RESOLVED_COMPONENT_RE = re.compile(r"^([A-Za-z0-9_.]+/[A-Za-z0-9_.$]+)$")
INTENT_NAME_RE = re.compile(r"^[A-Za-z0-9_]+(?:\.[A-Za-z0-9_]+)+$")
COMPONENT_RE_EXACT = re.compile(r"^([A-Za-z0-9_]+(?:\.[A-Za-z0-9_]+)+)/([A-Za-z0-9_.$]+)$")
EXTRA_FIELD_NAME_RE = re.compile(r"^[A-Za-z0-9_.-]{1,128}$")
DEVICE_API_COMMANDS = (
    "termux-audio-info", "termux-battery-status", "termux-brightness",
    "termux-call-log", "termux-camera-info", "termux-camera-photo",
    "termux-clipboard-get", "termux-clipboard-set", "termux-contact-list",
    "termux-dialog", "termux-fingerprint", "termux-infrared-frequencies",
    "termux-infrared-transmit", "termux-job-scheduler", "termux-keystore",
    "termux-location", "termux-media-player", "termux-media-scan",
    "termux-microphone-record", "termux-nfc", "termux-notification",
    "termux-notification-channel", "termux-notification-list",
    "termux-notification-remove", "termux-saf-create", "termux-saf-dirs",
    "termux-saf-ls", "termux-saf-managedir", "termux-saf-mkdir",
    "termux-saf-read", "termux-saf-rm", "termux-saf-stat", "termux-saf-write",
    "termux-sensor", "termux-share", "termux-sms-list", "termux-sms-send",
    "termux-speech-to-text", "termux-storage-get", "termux-telephony-call",
    "termux-telephony-cellinfo", "termux-telephony-deviceinfo", "termux-toast",
    "termux-torch", "termux-tts-engines", "termux-tts-speak", "termux-usb",
    "termux-vibrate", "termux-volume", "termux-wake-lock", "termux-wake-unlock",
    "termux-wallpaper", "termux-wifi-connectioninfo", "termux-wifi-scaninfo",
)
DEVICE_API_CONSTRAINTS = {
    "hardwareConditional": [
        "camera", "fingerprint", "infrared", "microphone", "nfc", "sensors", "telephony", "torch", "usb",
    ],
    "permissionOrConsentConditional": [
        "call-log", "camera", "contacts", "fingerprint", "location", "microphone",
        "notifications", "saf", "sms", "speech", "telephony", "usb",
    ],
    "stateChangingRequiresExplicitTask": [
        "brightness", "camera-photo", "clipboard-set", "infrared-transmit",
        "media-player", "notification", "saf-create", "saf-mkdir", "saf-rm",
        "saf-write", "share", "sms-send", "telephony-call", "torch", "vibrate",
        "volume", "wallpaper", "wake-lock",
    ],
}


def usage(stream=sys.stdout):
    print(
        "usage: codex-android capabilities|current|packages [fragment]|"
        "open <package-or-fragment>|app-info <package>|ui <android-shell-command>|"
        "intent|resolve-intent <json>|tap|longtap|swipe|text|key|keyevent|screenshot|dump ...",
        file=stream,
    )


def emit(payload):
    print(json.dumps(payload, separators=(",", ":"), sort_keys=True))


def resumed_component():
    result = run_rish("dumpsys activity activities")
    text = result.combined
    for pattern in (
        r"topResumedActivity=.*?\bu\d+\s+([^\s}]+/[^\s}]+)",
        r"mResumedActivity:.*?\bu\d+\s+([^\s}]+/[^\s}]+)",
    ):
        match = re.search(pattern, text)
        if match:
            return match.group(1)
    match = COMPONENT_RE.search(text)
    return match.group(1) if match else None


def visible_postcondition():
    component = resumed_component()
    return {
        "component": component,
        "package": component.split("/", 1)[0] if component else None,
        "verified": bool(component),
    }


def require_arity(args, minimum, maximum=None):
    maximum = minimum if maximum is None else maximum
    if not minimum <= len(args) <= maximum:
        usage(sys.stderr)
        raise SystemExit(2)


def integer(value, name, *, minimum=None, maximum=None):
    try:
        parsed = int(value)
    except (TypeError, ValueError) as error:
        raise AndroidPolicyError(name + "_integer") from error
    if minimum is not None and parsed < minimum:
        raise AndroidPolicyError(name + "_range")
    if maximum is not None and parsed > maximum:
        raise AndroidPolicyError(name + "_range")
    return parsed


def safe_download_output(value, suffix):
    if not isinstance(value, str) or "\x00" in value:
        raise AndroidPolicyError("download_output_path")
    normalized = (
        "/storage/emulated/0/" + value[len("/sdcard/"):]
        if value.startswith("/sdcard/") else value
    )
    pure = pathlib.PurePosixPath(normalized)
    root = pathlib.PurePosixPath("/storage/emulated/0/Download")
    if (
        not pure.is_absolute()
        or pure.suffix.casefold() != suffix
        or pure == root
        or pure.parts[:len(root.parts)] != root.parts
        or any(part in {"", ".", ".."} for part in pure.parts[1:])
    ):
        raise AndroidPolicyError("download_output_path")
    return pathlib.Path(str(pure))


def verify_xml_dump(path):
    if not path.is_file() or path.is_symlink() or not 1 <= path.stat().st_size <= 8 * 1024 * 1024:
        raise AndroidBridgeError("ui_dump_file_invalid")
    try:
        data = path.read_bytes()
        source = data.decode("utf-8", "strict")
        root = ET.fromstring(source)
    except (OSError, UnicodeDecodeError, ET.ParseError) as error:
        raise AndroidBridgeError("ui_dump_decode_invalid") from error
    if root.tag != "hierarchy":
        raise AndroidBridgeError("ui_dump_root_invalid")
    component = resumed_component()
    return {
        "path": str(path),
        "bytes": len(data),
        "sha256": hashlib.sha256(data).hexdigest(),
        "root": root.tag,
        "nodeCount": sum(1 for _ in root.iter("node")),
        "component": component,
        "package": component.split("/", 1)[0] if component else None,
        "verified": bool(component),
    }


def handle_open(target):
    matches = list_packages(target)
    try:
        exact = validate_package_id(target)
    except AndroidPolicyError:
        exact = None
    if exact and exact in matches:
        package = exact
    elif len(matches) == 1:
        package = matches[0]
    else:
        emit({"error": "package_not_unique", "matches": matches, "target": target, "verified": False})
        return 4
    resolved = run_rish(
        f"cmd package resolve-activity --brief --user 0 {shlex.quote(package)}"
    )
    components = [
        line.strip()
        for line in resolved.combined.splitlines()
        if RESOLVED_COMPONENT_RE.fullmatch(line.strip())
    ]
    if not components:
        emit({"error": "launchable_activity_not_found", "package": package, "verified": False})
        return 5
    component = components[-1]
    launched = run_rish(f"am start -W -n {shlex.quote(component)}", require_success=False)
    verified = None
    for _ in range(15):
        verified = resumed_component()
        if verified and verified.split("/", 1)[0] == package:
            break
        time.sleep(0.2)
    ok = bool(launched.remote_status == 0 and verified and verified.split("/", 1)[0] == package)
    emit(
        {
            "component": component,
            "package": package,
            "resumed": verified,
            "remoteStatus": launched.remote_status,
            "verified": ok,
        }
    )
    return 0 if ok else 5


def handle_input(action, args):
    if action == "tap":
        require_arity(args, 2)
        x, y = (integer(value, "coordinate", minimum=0, maximum=100000) for value in args)
        command = f"input tap {x} {y}"
    elif action == "longtap":
        require_arity(args, 2, 3)
        x = integer(args[0], "coordinate", minimum=0, maximum=100000)
        y = integer(args[1], "coordinate", minimum=0, maximum=100000)
        duration = integer(args[2], "duration", minimum=100, maximum=60000) if len(args) == 3 else 800
        command = f"input swipe {x} {y} {x} {y} {duration}"
    elif action == "swipe":
        require_arity(args, 4, 5)
        values = [integer(value, "coordinate", minimum=0, maximum=100000) for value in args[:4]]
        duration = integer(args[4], "duration", minimum=1, maximum=60000) if len(args) == 5 else 300
        command = "input swipe %d %d %d %d %d" % (*values, duration)
    elif action == "text":
        require_arity(args, 1)
        command = "input text " + shlex.quote(args[0])
    else:
        require_arity(args, 1)
        key = integer(args[0], "keycode", minimum=0, maximum=10000)
        command = f"input keyevent {key}"
    result = run_rish(command, require_success=False)
    postcondition = visible_postcondition()
    postcondition.update({"action": action, "remoteStatus": result.remote_status})
    postcondition["verified"] = result.remote_status == 0 and postcondition["verified"]
    emit(postcondition)
    return 0 if postcondition["verified"] else 5


def intent_spec(raw):
    try:
        value = json.loads(raw)
    except json.JSONDecodeError as error:
        raise AndroidPolicyError("intent_json") from error
    if not isinstance(value, dict):
        raise AndroidPolicyError("intent_schema")
    allowed = {"kind", "action", "data", "type", "categories", "package", "component", "flags", "extras"}
    if set(value) - allowed:
        raise AndroidPolicyError("intent_unknown_field")
    kind = value.get("kind", "activity")
    if kind not in {"activity", "broadcast", "service"}:
        raise AndroidPolicyError("intent_kind")
    action = value.get("action")
    if not isinstance(action, str) or not INTENT_NAME_RE.fullmatch(action):
        raise AndroidPolicyError("intent_action")
    data = value.get("data")
    if data is not None:
        if not isinstance(data, str) or not 1 <= len(data) <= 4096 or any(ord(ch) < 32 for ch in data):
            raise AndroidPolicyError("intent_data")
        parsed = urllib.parse.urlsplit(data)
        if not parsed.scheme or not re.fullmatch(r"[A-Za-z][A-Za-z0-9+.-]{0,31}", parsed.scheme):
            raise AndroidPolicyError("intent_data")
        if parsed.scheme.casefold() == "file":
            raise AndroidPolicyError("intent_file_uri")
    mime_type = value.get("type")
    if mime_type is not None and (
        not isinstance(mime_type, str)
        or not re.fullmatch(r"[A-Za-z0-9!#$&^_.+-]+/[A-Za-z0-9!#$&^_.+*-]+", mime_type)
    ):
        raise AndroidPolicyError("intent_mime")
    package = validate_package_id(value["package"]) if value.get("package") is not None else None
    component = value.get("component")
    if component is not None:
        match = COMPONENT_RE_EXACT.fullmatch(component) if isinstance(component, str) else None
        if not match:
            raise AndroidPolicyError("intent_component")
        component_package = validate_package_id(match.group(1))
        if package and package != component_package:
            raise AndroidPolicyError("intent_target_conflict")
        package = component_package
    categories = value.get("categories", [])
    if not isinstance(categories, list) or len(categories) > 16:
        raise AndroidPolicyError("intent_categories")
    if any(not isinstance(item, str) or not INTENT_NAME_RE.fullmatch(item) for item in categories):
        raise AndroidPolicyError("intent_category")
    flags = value.get("flags")
    if flags is not None and (isinstance(flags, bool) or not isinstance(flags, int) or not 0 <= flags <= 0xFFFFFFFF):
        raise AndroidPolicyError("intent_flags")
    extras = value.get("extras", {})
    if not isinstance(extras, dict) or len(extras) > 32:
        raise AndroidPolicyError("intent_extras")
    arguments = ["-a", action]
    if data is not None:
        arguments.extend(("-d", data))
    if mime_type is not None:
        arguments.extend(("-t", mime_type))
    for category in categories:
        arguments.extend(("-c", category))
    if package:
        arguments.extend(("-p", package))
    if component:
        arguments.extend(("-n", component))
    if flags is not None:
        arguments.extend(("-f", str(flags)))
    for key, extra in extras.items():
        if not isinstance(key, str) or not EXTRA_FIELD_NAME_RE.fullmatch(key):
            raise AndroidPolicyError("intent_extra_key")
        if isinstance(extra, bool):
            arguments.extend(("--ez", key, "true" if extra else "false"))
        elif isinstance(extra, int) and not isinstance(extra, bool) and -(2**63) <= extra < 2**63:
            arguments.extend(("--el", key, str(extra)))
        elif isinstance(extra, str) and len(extra) <= 4096 and not any(ord(ch) < 32 for ch in extra):
            arguments.extend(("--es", key, extra))
        elif isinstance(extra, dict) and set(extra) == {"type", "value"} and extra.get("type") == "uri":
            uri = extra.get("value")
            parsed_uri = urllib.parse.urlsplit(uri) if isinstance(uri, str) else None
            if (
                not parsed_uri or parsed_uri.scheme not in {"content", "http", "https"}
                or len(uri) > 4096 or any(ord(ch) < 32 for ch in uri)
            ):
                raise AndroidPolicyError("intent_extra_uri")
            arguments.extend(("--eu", key, uri))
        else:
            raise AndroidPolicyError("intent_extra_value")
    return {"kind": kind, "action": action, "package": package, "component": component, "arguments": arguments}


def handle_intent(raw, *, resolve_only=False):
    spec = intent_spec(raw)
    quoted = " ".join(shlex.quote(item) for item in spec["arguments"])
    if resolve_only:
        if spec["kind"] != "activity":
            raise AndroidPolicyError("intent_resolve_kind")
        result = run_rish("cmd package resolve-activity --brief --user 0 " + quoted, require_success=False)
        components = [line.strip() for line in result.combined.splitlines() if RESOLVED_COMPONENT_RE.fullmatch(line.strip())]
        component = components[-1] if components else None
        emit({"action": spec["action"], "component": component, "package": component.split("/", 1)[0] if component else None,
              "remoteStatus": result.remote_status, "verified": result.remote_status == 0 and component is not None})
        return 0 if result.remote_status == 0 and component is not None else 5
    prefix = {
        "activity": "am start -W --user 0 ",
        "broadcast": "am broadcast --user 0 ",
        "service": "am start-foreground-service --user 0 ",
    }[spec["kind"]]
    result = run_rish(prefix + quoted, require_success=False)
    resumed = resumed_component() if spec["kind"] == "activity" else None
    if spec["kind"] == "activity":
        visible_package = resumed.split("/", 1)[0] if resumed else None
        expected = spec["package"]
        verified = result.remote_status == 0 and "Status: ok" in result.combined and bool(resumed)
        if expected:
            verified = verified and visible_package == expected
    elif spec["kind"] == "broadcast":
        verified = result.remote_status == 0 and "Broadcast completed" in result.combined
    else:
        verified = result.remote_status == 0 and "Starting service" in result.combined
    emit({"kind": spec["kind"], "action": spec["action"], "package": spec["package"], "component": spec["component"],
          "resumed": resumed, "remoteStatus": result.remote_status, "verified": verified})
    return 0 if verified else 5


def main():
    args = sys.argv[1:]
    if not args or args[0] in {"-h", "--help"}:
        usage()
        return 0
    action = args.pop(0)
    try:
        if action == "capabilities":
            require_arity(args, 0)
            emit(
                {
                    "actions": [
                        "current", "packages", "open", "app-info", "ui", "shell",
                        "tap", "longtap", "swipe", "text", "key", "keyevent",
                        "screenshot", "dump", "settings", "force-stop", "url",
                        "intent", "resolve-intent",
                    ],
                    "backend": "isolated-shizuku-rish",
                    "deviceApis": [
                        command for command in DEVICE_API_COMMANDS
                        if pathlib.Path("/data/data/com.termux/files/usr/bin", command).is_file()
                    ],
                    "deviceApiConstraints": DEVICE_API_CONSTRAINTS,
                    "deviceApiDiscovery": "installed-command-plus-runtime-permission-and-hardware-check",
                    "launchVerification": "fresh-top-resumed-activity",
                    "protectedPackages": sorted(PROTECTED_PACKAGES),
                }
            )
            return 0
        if action == "current":
            require_arity(args, 0)
            payload = visible_postcondition()
            emit(payload)
            return 0 if payload["verified"] else 5
        if action == "packages":
            require_arity(args, 0, 1)
            packages = list_packages(args[0] if args else None)
            emit({"ok": True, "count": len(packages), "packages": packages, "verified": True})
            return 0
        if action == "launch":
            print("codex-android launch is unsupported; use codex-android open", file=sys.stderr)
            return 2
        if action == "open":
            require_arity(args, 1)
            return handle_open(args[0])
        if action == "app-info":
            require_arity(args, 1)
            emit(package_evidence(args[0]))
            return 0
        if action in {"intent", "resolve-intent"}:
            require_arity(args, 1)
            return handle_intent(args[0], resolve_only=action == "resolve-intent")
        if action in {"ui", "shell"}:
            require_arity(args, 1, 1000)
            command = args[0] if len(args) == 1 else shlex.join(args)
            validate_android_shell_command(command)
            result = run_rish(command, require_success=False)
            if result.stdout:
                sys.stdout.write(result.stdout + ("\n" if not result.stdout.endswith("\n") else ""))
            if result.stderr:
                sys.stderr.write(result.stderr + ("\n" if not result.stderr.endswith("\n") else ""))
            return result.remote_status
        if action in {"tap", "longtap", "swipe", "text", "key", "keyevent"}:
            return handle_input(action, args)
        if action == "force-stop":
            require_arity(args, 1)
            package = validate_package_id(args[0])
            if package_is_protected(package):
                raise AndroidPolicyError("protected_package_mutation")
            command = f"am force-stop {shlex.quote(package)}"
            stopped = run_rish(command)
            absent = run_rish(
                f"if pidof {shlex.quote(package)} >/dev/null 2>&1; then exit 5; else exit 0; fi",
                require_success=False,
            )
            ok = stopped.remote_status == 0 and absent.remote_status == 0
            emit({"package": package, "stopped": ok, "verified": ok})
            return 0 if ok else 5
        if action == "screenshot":
            require_arity(args, 0, 1)
            path = safe_download_output(
                args[0] if args else "/storage/emulated/0/Download/nemotron-screenshot.png",
                ".png",
            )
            result = run_rish("screencap -p " + shlex.quote(str(path)))
            receipt = verify_png_file(path)
            component = resumed_component()
            receipt.update({
                "captured": result.remote_status == 0,
                "component": component,
                "package": component.split("/", 1)[0] if component else None,
            })
            receipt["verified"] = (
                result.remote_status == 0 and receipt["verified"] and bool(component)
            )
            emit(receipt)
            return 0
        if action == "dump":
            require_arity(args, 0, 1)
            path = safe_download_output(
                args[0] if args else "/storage/emulated/0/Download/nemotron-window.xml",
                ".xml",
            )
            result = run_rish("uiautomator dump " + shlex.quote(str(path)))
            receipt = verify_xml_dump(path)
            receipt["captured"] = result.remote_status == 0
            receipt["verified"] = result.remote_status == 0 and receipt["verified"]
            emit(receipt)
            return 0
        if action == "settings":
            require_arity(args, 1, 1000)
            command = "settings " + shlex.join(args)
            result = run_rish(command, require_success=False)
            if result.stdout:
                print(result.stdout)
            if result.stderr:
                print(result.stderr, file=sys.stderr)
            return result.remote_status
        if action == "url":
            require_arity(args, 1)
            return subprocess.call([str(pathlib.Path(__file__).with_name("codex-open-url")), args[0]])
        usage(sys.stderr)
        return 2
    except AndroidPolicyError as error:
        print(sanitized_policy_message(error), file=sys.stderr)
        return 77
    except AndroidBridgeError as error:
        emit(
            {
                "ok": False,
                "error": error.code,
                "remoteStatus": error.remote_status,
                "verified": False,
            }
        )
        return 69


if __name__ == "__main__":
    raise SystemExit(main())
