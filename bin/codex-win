#!/data/data/com.termux/files/usr/bin/python
"""Use the existing global Windows credential broker from every Nemotron session."""

import json
import os
import fcntl
import pathlib
import subprocess
import sys
import time

from nemotron_automation import AutomationState
from nemotron_automation import safe_mode_status
from nemotron_powershell_policy import (
    CLEANUP_ACTION,
    CLEANUP_PHASES,
    PolicyViolation,
    prepare_gateway_payload,
    sanitized_policy_message,
    validate_powershell_gateway_tail,
)


GLOBAL_RUNTIME_ROOT = "/data/data/com.termux/files/home/.codex"
GLOBAL_COMMAND = "/data/data/com.termux/files/home/.local/bin/codex-win"
AUTOMATION_ROOT = pathlib.Path(
    os.environ.get(
        "NEMOTRON_AUTOMATION_STATE",
        str(pathlib.Path(__file__).resolve().parents[1] / "runtime" / ".codex" / "automation"),
    )
)
PC_CACHE_TTL_SECONDS = 30


def usage():
    print("usage: codex-win '<json-payload>' [--timeout seconds] [--fresh]\n"
          "read-only: {\"action\":\"status\"} or {\"action\":\"diagnostics\"}\n"
          "queries: {\"action\":\"powershell\",\"command\":\"Get-...\"}")


def main():
    args = sys.argv[1:]
    if not args or args[0] in {"-h", "--help"}:
        usage()
        return 0
    if safe_mode_status()["active"]:
        sys.stderr.write(json.dumps({
            "action": "Enforce local-only safe mode",
            "ok": False,
            "error": "local_only_safe_mode_active",
            "message": "Windows gateway networking is disabled while local-only safe mode is active.",
            "status": "blocked",
            "verified": False,
        }, separators=(",", ":"), sort_keys=True) + "\n")
        return 6
    fresh = "--fresh" in args[1:]
    tail = [value for value in args[1:] if value != "--fresh"]
    try:
        validate_powershell_gateway_tail(tail)
        requested_action = json.loads(args[0]).get("action")
        gateway_payload = prepare_gateway_payload(args[0])
    except (AttributeError, json.JSONDecodeError):
        sys.stderr.write("PowerShell request blocked by local policy (gateway_payload_json).\n")
        return 64
    except PolicyViolation as error:
        sys.stderr.write(sanitized_policy_message(error) + "\n")
        return 64
    env = dict(os.environ, CODEX_RUNTIME_ROOT=GLOBAL_RUNTIME_ROOT)
    is_status = False
    is_diagnostics = False
    is_read_only_powershell = False
    try:
        is_status = json.loads(args[0]).get("action") == "status"
        is_diagnostics = json.loads(args[0]).get("action") == "diagnostics"
        is_read_only_powershell = json.loads(args[0]).get("action") == "powershell"
    except (AttributeError, json.JSONDecodeError):
        pass
    command_args = [gateway_payload, *tail]
    if (is_status or is_diagnostics) and "--timeout" not in command_args:
        command_args.extend(("--timeout", "5"))
    gateway_timeout = 5 if (is_status or is_diagnostics) else 60
    if "--timeout" in command_args:
        gateway_timeout = int(command_args[command_args.index("--timeout") + 1])
    process_timeout = gateway_timeout + 15
    attempts = 3 if (is_status or is_diagnostics or is_read_only_powershell) else 1
    last = None
    timeout_error = None
    automation = AutomationState(AUTOMATION_ROOT)

    if requested_action in {"status", "diagnostics"} and not fresh:
        cached = automation.cache_get("pc_gateway", requested_action)
        if cached and isinstance(cached.get("value"), dict):
            response = dict(cached["value"])
            response["cacheStatus"] = "verified-cache"
            response["cacheAgeSeconds"] = cached["ageSeconds"]
            response["message"] = (
                "The paired Windows identity was verified recently; this receipt is from the "
                "bounded 30-second cache."
            )
            sys.stdout.write(json.dumps(response, separators=(",", ":"), sort_keys=True) + "\n")
            return 0

    circuit = automation.circuit_status("pc_gateway")
    if not circuit["allow"] and requested_action not in {"status", "diagnostics"}:
        sys.stderr.write(json.dumps({
            "action": "Check the paired Windows circuit before dispatch",
            "ok": False,
            "error": "windows_gateway_circuit_open",
            "message": "Repeated verified gateway failures opened the circuit; no Windows action was dispatched.",
            "nextAction": "Wait for the cooldown, then run one fresh status or diagnostics probe.",
            "status": "blocked",
            "verified": False,
        }, separators=(",", ":"), sort_keys=True) + "\n")
        return 6

    def response_is_verified(process, response):
        if not (
            process.returncode == 0
            and isinstance(response, dict)
            and response.get("ok") is True
            and response.get("exitCode") == 0
        ):
            return False
        if response.get("verified") is True:
            return True
        if requested_action == "diagnostics":
            listener = response.get("listener")
            process = response.get("process")
            return bool(
                response.get("action") == "diagnostics"
                and isinstance(listener, dict)
                and listener.get("loopback") is True
                and isinstance(listener.get("port"), int) and 1 <= listener["port"] <= 65535
                and isinstance(listener.get("tailnetAddress"), str) and listener["tailnetAddress"]
                and isinstance(process, dict)
                and isinstance(process.get("computer"), str) and process["computer"]
                and isinstance(process.get("user"), str) and process["user"]
                and isinstance(process.get("elevated"), bool)
                and isinstance(process.get("startedAt"), str) and process["startedAt"]
            )
        if requested_action == "powershell":
            return bool(
                response.get("action") == "shell"
                and response.get("timedOut") is False
                and isinstance(response.get("elevated"), bool)
                and isinstance(response.get("stdout"), str)
                and isinstance(response.get("stderr"), str)
                and isinstance(response.get("startedAt"), str) and response["startedAt"]
                and isinstance(response.get("finishedAt"), str) and response["finishedAt"]
            )
        if requested_action == "status":
            policy = response.get("policy")
            return bool(
                response.get("companion") == "CODEX_PC_BRIDGE_READY"
                and response.get("gateway") == "CODEX_WINDOWS_AUTONOMY_GATEWAY_READY"
                and isinstance(response.get("computer"), str) and response["computer"]
                and isinstance(response.get("user"), str) and response["user"]
                and isinstance(response.get("elevated"), bool)
                and isinstance(response.get("port"), int) and 1 <= response["port"] <= 65535
                and isinstance(response.get("tailnetAddress"), str) and response["tailnetAddress"]
                and isinstance(response.get("time"), str) and response["time"]
                and isinstance(policy, dict)
                and policy.get("interactiveApprovalRequired") is False
                and isinstance(policy.get("readOnlyActions"), list)
                and isinstance(policy.get("stateChangingActions"), list)
            )
        if requested_action == "powershell_github":
            return bool(
                response.get("action") == "shell"
                and response.get("timedOut") is False
                and isinstance(response.get("elevated"), bool)
                and isinstance(response.get("stdout"), str)
                and isinstance(response.get("stderr"), str)
                and isinstance(response.get("startedAt"), str) and response["startedAt"]
                and isinstance(response.get("finishedAt"), str) and response["finishedAt"]
            )
        if requested_action == CLEANUP_ACTION:
            if not (
                response.get("action") == "shell"
                and response.get("timedOut") is False
                and isinstance(response.get("stdout"), str)
                and isinstance(response.get("stderr"), str)
                and isinstance(response.get("startedAt"), str) and response["startedAt"]
                and isinstance(response.get("finishedAt"), str) and response["finishedAt"]
            ):
                return False
            try:
                receipt = json.loads(response["stdout"])
            except (TypeError, json.JSONDecodeError):
                return False
            requested = receipt.get("requestedCount")
            verification = receipt.get("verification")
            receipts = receipt.get("receipts")
            return bool(
                receipt.get("ok") is True
                and receipt.get("phases") == list(CLEANUP_PHASES)
                and isinstance(requested, int) and 1 <= requested <= 16
                and isinstance(verification, list) and len(verification) == requested
                and isinstance(receipts, list) and len(receipts) == requested
                and all(
                    isinstance(item, dict)
                    and item.get("Removed") is True
                    and isinstance(item.get("LiteralPath"), str)
                    and item["LiteralPath"]
                    for item in verification
                )
            )
        # The current Windows bridge marks generic PowerShell transport
        # envelopes completed_unverified even when the bounded read-only
        # GitHub probe emits its own machine-verifiable JSON receipt. Accept
        # only that exact status action and only when the inner receipt is
        # successful and explicitly verified. State-changing actions remain
        # fail-closed on the outer gateway receipt.
        if requested_action != "powershell_github_status":
            return False
        try:
            receipt = json.loads(response.get("stdout", ""))
        except (TypeError, json.JSONDecodeError):
            return False
        return bool(
            isinstance(receipt, dict)
            and receipt.get("ok") is True
            and receipt.get("verified") is True
            and isinstance(receipt.get("gitAvailable"), bool)
            and isinstance(receipt.get("ghAvailable"), bool)
            and isinstance(receipt.get("authenticated"), bool)
        )

    for attempt in range(attempts):
        try:
            AUTOMATION_ROOT.mkdir(parents=True, exist_ok=True)
            with (AUTOMATION_ROOT / "pc-gateway.lock").open("a+") as lock:
                fcntl.flock(lock, fcntl.LOCK_EX)
                last = subprocess.run(
                    [GLOBAL_COMMAND, *command_args],
                    env=env,
                    capture_output=True,
                    text=True,
                    timeout=process_timeout,
                )
            timeout_error = None
        except subprocess.TimeoutExpired:
            timeout_error = (
                "Paired Windows gateway did not answer before the bounded timeout; "
                "the requested action was not reported as completed.\n"
            )
            last = None
            if not (is_status or is_diagnostics or is_read_only_powershell):
                break
            if attempt + 1 < attempts:
                time.sleep(attempt + 1)
            continue
        if last.returncode == 0:
            try:
                response = json.loads(last.stdout)
            except json.JSONDecodeError:
                response = None
            if response_is_verified(last, response):
                break
        if attempt + 1 < attempts:
            time.sleep(attempt + 1)
    if last is None:
        if timeout_error:
            sys.stderr.write(timeout_error)
        return 1
    try:
        response = json.loads(last.stdout)
    except json.JSONDecodeError:
        response = None
    verified = response_is_verified(last, response)
    if not verified:
        automation.cache_delete("pc_gateway", "status")
        automation.cache_delete("pc_gateway", "diagnostics")
        automation.circuit_failure("pc_gateway", "windows_gateway_unverified")
        automation.increment("pc_gateway_failure")
        if last.returncode != 0:
            reason = "The paired Windows gateway process failed before returning a verified receipt."
        elif not isinstance(response, dict):
            reason = "The paired Windows gateway returned data that was not a valid structured receipt."
        elif response.get("ok") is not True:
            reason = "The paired Windows gateway reported that the requested action did not complete."
        elif response.get("exitCode") != 0:
            reason = "The Windows action returned a non-zero exit code and was not accepted as complete."
        else:
            reason = (
                "The Windows action returned an incomplete verification receipt, so no successful "
                "result was claimed."
            )
        sys.stderr.write(
            json.dumps(
                {
                    "action": "Verify the paired Windows action and its postcondition",
                    "ok": False,
                    "error": "windows_gateway_unverified",
                    "message": reason,
                    "nextAction": (
                        "Run bounded status and diagnostics, then retry only after the exact "
                        "gateway receipt is complete."
                    ),
                    "processExitCode": last.returncode,
                    "status": "verification_failed",
                    "verified": False,
                },
                separators=(",", ":"),
                sort_keys=True,
            )
            + "\n"
        )
        return 5
    if requested_action in {"status", "diagnostics", "powershell"} and response.get("verified") is not True:
        response = dict(response)
        response["upstreamStatus"] = response.get("status")
        response["upstreamVerified"] = False
        response["verified"] = True
        response["localVerificationStatus"] = "verified"
        response["verificationBasis"] = (
            "local-read-only-policy-plus-exact-shell-receipt"
            if requested_action == "powershell"
            else f"exact-{requested_action}-receipt"
        )
    elif requested_action == "powershell_github":
        response = dict(response)
        response["upstreamStatus"] = response.get("status")
        response["upstreamVerified"] = response.get("verified") is True
        response["executionVerified"] = True
        response["verified"] = False
        response["status"] = "completed_pending_postcondition"
        response["verificationBasis"] = "validated-direct-git-or-gh-command-plus-exact-shell-receipt"
    elif requested_action == CLEANUP_ACTION:
        response = dict(response)
        response["upstreamStatus"] = response.get("status")
        response["upstreamVerified"] = response.get("verified") is True
        response["verified"] = True
        response["status"] = "completed"
        response["localVerificationStatus"] = "verified"
        response["verificationBasis"] = "fixed-six-phase-cleanup-plus-per-target-absence-readback"
        response["cleanupReceipt"] = json.loads(response["stdout"])
    if isinstance(response, dict):
        response = dict(response)
        response["actionSummary"] = {
            "status": "Check the paired Windows gateway and authenticated bridge",
            "diagnostics": "Diagnose the paired Windows listener, route, and process identity",
            "powershell": "Run the validated read-only Windows query and verify its receipt",
            "powershell_github": "Run the authenticated direct Git or GitHub command",
            CLEANUP_ACTION: "Delete only the classified Windows targets and verify every absence",
        }.get(requested_action, "Run the validated paired Windows action")
        if not response.get("message"):
            if requested_action == "powershell_github":
                response["message"] = (
                    "The authenticated direct Git or GitHub command exited successfully; verify its "
                    "repository effect with a separate readback before claiming completion."
                )
            elif requested_action == CLEANUP_ACTION:
                response["message"] = (
                    "The fixed cleanup workflow completed inventory, classification, exclusion, "
                    "manifest, execution, and per-target absence verification."
                )
            else:
                response["message"] = (
                    "The paired Windows action completed and its exact receipt was independently verified."
                )
        response["cacheStatus"] = "live"
        response["cacheAgeSeconds"] = 0
    automation.circuit_success("pc_gateway")
    automation.increment("pc_gateway_success")
    if requested_action in {"status", "diagnostics"}:
        automation.cache_set("pc_gateway", requested_action, response, PC_CACHE_TTL_SECONDS)
    sys.stdout.write(json.dumps(response, separators=(",", ":"), sort_keys=True) + "\n")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
