#!/data/data/com.termux/files/usr/bin/python
"""Android-Keystore-bound AES-GCM secrets with scoped process injection."""

import argparse
import base64
import datetime as dt
import hashlib
import json
import os
import pathlib
import re
import shutil
import subprocess
import sys
import tempfile

from cryptography.hazmat.primitives.ciphers.aead import AESGCM


ROOT = pathlib.Path(__file__).resolve().parents[1]
STATE = pathlib.Path(os.environ.get(
    "NEMOTRON_SECRET_STATE", str(ROOT / "runtime" / ".codex" / "automation" / "secrets")
))
KEYSTORE = "/data/data/com.termux/files/usr/bin/termux-keystore"
ALIAS = "nemotron_automation_secrets_v1"
NAME = re.compile(r"^[a-z][a-z0-9_.-]{1,63}$")
SCOPE = re.compile(r"^[a-z][a-z0-9_.-]{1,63}$")
ENV_NAME = re.compile(r"^[A-Z][A-Z0-9_]{1,63}$")
EXECUTABLE = re.compile(r"^[A-Za-z0-9_.+-]{1,128}$")


class SecretError(Exception):
    pass


def now():
    return dt.datetime.now(dt.timezone.utc).isoformat()


def atomic_json(path, value):
    path.parent.mkdir(parents=True, exist_ok=True, mode=0o700)
    fd, temporary = tempfile.mkstemp(prefix=path.name + ".", dir=path.parent)
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as stream:
            json.dump(value, stream, indent=2, sort_keys=True)
            stream.write("\n")
            stream.flush()
            os.fsync(stream.fileno())
        os.chmod(temporary, 0o600)
        os.replace(temporary, path)
    finally:
        if os.path.exists(temporary):
            os.unlink(temporary)


def validate_name(value):
    if not NAME.fullmatch(value):
        raise SecretError("secret_name_invalid")
    return value


def derive_key():
    if os.environ.get("CODEX_RUNTIME_TEST_MODE") == "1":
        value = os.environ.get("NEMOTRON_SECRET_TEST_KEY")
        if not value or len(value) < 32:
            raise SecretError("test_key_missing")
        return hashlib.sha256(value.encode()).digest()
    listed = subprocess.run([KEYSTORE, "list"], input=b"", capture_output=True, timeout=30, check=False)
    if listed.returncode != 0:
        raise SecretError("keystore_unavailable")
    try:
        aliases = json.loads(listed.stdout.decode("utf-8"))
    except json.JSONDecodeError as error:
        raise SecretError("keystore_list_invalid") from error
    alias_names = {
        item if isinstance(item, str) else item.get("alias")
        for item in aliases if isinstance(item, (str, dict))
    }
    if ALIAS not in alias_names:
        generated = subprocess.run(
            [KEYSTORE, "generate", ALIAS, "-a", "RSA", "-s", "3072"],
            input=b"", capture_output=True, timeout=120, check=False,
        )
        if generated.returncode != 0:
            raise SecretError("keystore_key_generation_failed")
    signed = subprocess.run(
        [KEYSTORE, "sign", ALIAS, "SHA256withRSA"],
        input=b"nemotron-automation-secrets-v1", capture_output=True, timeout=30, check=False,
    )
    if signed.returncode != 0 or len(signed.stdout) < 256:
        raise SecretError("keystore_signature_failed")
    return hashlib.sha256(signed.stdout + b"\0aes-gcm-v1").digest()


def encrypt(value, key, aad):
    nonce = os.urandom(12)
    ciphertext = AESGCM(key).encrypt(nonce, value, aad)
    return {
        "algorithm": "AES-256-GCM",
        "nonce": base64.b64encode(nonce).decode(),
        "ciphertext": base64.b64encode(ciphertext).decode(),
    }


def decrypt(record, key, aad):
    if record.get("algorithm") != "AES-256-GCM":
        raise SecretError("secret_algorithm_invalid")
    try:
        return AESGCM(key).decrypt(
            base64.b64decode(record["nonce"], validate=True),
            base64.b64decode(record["ciphertext"], validate=True),
            aad,
        )
    except Exception as error:
        raise SecretError("secret_authentication_failed") from error


def record_path(name):
    return STATE / "active" / f"{name}.json"


def load(name):
    try:
        value = json.loads(record_path(name).read_text(encoding="utf-8"))
    except FileNotFoundError as error:
        raise SecretError("secret_not_found") from error
    except json.JSONDecodeError as error:
        raise SecretError("secret_record_invalid") from error
    if value.get("name") != name:
        raise SecretError("secret_record_identity_mismatch")
    return value


def aad(record):
    public = {key: record[key] for key in ("schemaVersion", "name", "scopes", "allowedExecutables", "version")}
    return json.dumps(public, sort_keys=True, separators=(",", ":")).encode()


def metadata(record):
    return {key: record.get(key) for key in (
        "name", "scopes", "allowedExecutables", "version", "createdAt", "rotatedAt", "lastUsedAt",
    )}


def main():
    parser = argparse.ArgumentParser(description="Store and use scoped secrets without plaintext arguments or logs.")
    commands = parser.add_subparsers(dest="command", required=True)
    set_command = commands.add_parser("set")
    set_command.add_argument("name")
    set_command.add_argument("--scope", action="append", required=True)
    set_command.add_argument("--allow-executable", action="append", required=True)
    rotate = commands.add_parser("rotate")
    rotate.add_argument("name")
    commands.add_parser("list")
    status = commands.add_parser("status")
    status.add_argument("name")
    run = commands.add_parser("run")
    run.add_argument("name")
    run.add_argument("--scope", required=True)
    run.add_argument("--env", required=True)
    run.add_argument("argv", nargs="+")
    delete = commands.add_parser("delete")
    delete.add_argument("name")
    delete.add_argument("--yes", action="store_true")
    restore = commands.add_parser("restore")
    restore.add_argument("name")
    args = parser.parse_args()
    try:
        STATE.mkdir(parents=True, exist_ok=True, mode=0o700)
        os.chmod(STATE, 0o700)
        if args.command == "list":
            values = []
            for path in sorted((STATE / "active").glob("*.json")) if (STATE / "active").exists() else []:
                record = json.loads(path.read_text(encoding="utf-8"))
                values.append(metadata(record))
            output = {
                "schemaVersion": 1, "processCompleted": True, "taskVerified": True,
                "secrets": values, "message": "Listed secret metadata without decrypting or exposing values.",
            }
        elif args.command == "set":
            name = validate_name(args.name)
            if record_path(name).exists():
                raise SecretError("secret_already_exists")
            scopes = sorted(set(args.scope))
            executables = sorted(set(args.allow_executable))
            if any(not SCOPE.fullmatch(item) for item in scopes) or any(not EXECUTABLE.fullmatch(item) for item in executables):
                raise SecretError("secret_policy_invalid")
            value = sys.stdin.buffer.read(64 * 1024 + 1)
            if not value or len(value) > 64 * 1024:
                raise SecretError("secret_value_invalid")
            record = {
                "schemaVersion": 1, "name": name, "scopes": scopes,
                "allowedExecutables": executables, "version": 1, "createdAt": now(),
                "rotatedAt": None, "lastUsedAt": None,
            }
            record.update(encrypt(value, derive_key(), aad(record)))
            atomic_json(record_path(name), record)
            output = {
                "schemaVersion": 1, "processCompleted": True, "taskVerified": True,
                "secret": metadata(record), "message": "Encrypted the stdin secret with its exact scope and executable policy.",
            }
        elif args.command == "rotate":
            name = validate_name(args.name)
            record = load(name)
            value = sys.stdin.buffer.read(64 * 1024 + 1)
            if not value or len(value) > 64 * 1024:
                raise SecretError("secret_value_invalid")
            archive = STATE / "archive" / name / f"v{record['version']}.json"
            atomic_json(archive, record)
            record["version"] += 1
            record["rotatedAt"] = now()
            record.update(encrypt(value, derive_key(), aad(record)))
            atomic_json(record_path(name), record)
            output = {
                "schemaVersion": 1, "processCompleted": True, "taskVerified": True,
                "secret": metadata(record), "message": "Rotated the secret and preserved only its prior encrypted record.",
            }
        elif args.command == "status":
            record = load(validate_name(args.name))
            decrypt(record, derive_key(), aad(record))
            output = {
                "schemaVersion": 1, "processCompleted": True, "taskVerified": True,
                "secret": metadata(record), "message": "Authenticated the encrypted secret without exposing its value.",
            }
        elif args.command == "run":
            name = validate_name(args.name)
            record = load(name)
            if args.scope not in record["scopes"]:
                raise SecretError("secret_scope_denied")
            if not ENV_NAME.fullmatch(args.env) or not args.argv:
                raise SecretError("secret_run_invalid")
            executable = pathlib.Path(args.argv[0]).name
            if executable not in record["allowedExecutables"]:
                raise SecretError("secret_executable_denied")
            located = shutil.which(args.argv[0]) if "/" not in args.argv[0] else args.argv[0]
            resolved = pathlib.Path(located).resolve(strict=True) if located else None
            trusted_roots = (
                pathlib.Path("/data/data/com.termux/files/usr/bin").resolve(),
                (ROOT / "bin").resolve(),
            )
            if not resolved or not resolved.is_file() or not any(resolved == root or root in resolved.parents for root in trusted_roots):
                raise SecretError("secret_executable_untrusted")
            secret = decrypt(record, derive_key(), aad(record))
            text_secret = secret.decode("utf-8")
            env = dict(os.environ)
            env[args.env] = text_secret
            completed = subprocess.run(
                [str(pathlib.Path(located).absolute()), *args.argv[1:]], cwd=ROOT, env=env,
                capture_output=True, text=True, timeout=300, check=False,
            )
            stdout = completed.stdout.replace(text_secret, "[REDACTED]")
            stderr = completed.stderr.replace(text_secret, "[REDACTED]")
            record["lastUsedAt"] = now()
            atomic_json(record_path(name), record)
            output = {
                "schemaVersion": 1, "processCompleted": completed.returncode == 0,
                "taskVerified": completed.returncode == 0, "exitCode": completed.returncode,
                "stdout": stdout[-16_000:], "stderr": stderr[-16_000:],
                "secret": metadata(record),
                "message": "Ran the exact allowed executable with scoped environment injection and redacted output.",
            }
        elif args.command == "delete":
            name = validate_name(args.name)
            if not args.yes:
                raise SecretError("secret_delete_confirmation_required")
            record = load(name)
            destination = STATE / "deleted" / f"{name}.json"
            if destination.exists():
                raise SecretError("deleted_secret_conflict")
            destination.parent.mkdir(parents=True, exist_ok=True, mode=0o700)
            os.replace(record_path(name), destination)
            output = {
                "schemaVersion": 1, "processCompleted": True, "taskVerified": True,
                "secret": metadata(record), "message": "Moved the encrypted secret to recoverable deleted state without decrypting it.",
            }
        else:
            name = validate_name(args.name)
            source = STATE / "deleted" / f"{name}.json"
            if not source.is_file() or record_path(name).exists():
                raise SecretError("deleted_secret_not_restorable")
            record = json.loads(source.read_text(encoding="utf-8"))
            decrypt(record, derive_key(), aad(record))
            record_path(name).parent.mkdir(parents=True, exist_ok=True, mode=0o700)
            os.replace(source, record_path(name))
            output = {
                "schemaVersion": 1, "processCompleted": True, "taskVerified": True,
                "secret": metadata(record), "message": "Authenticated and restored the encrypted secret record.",
            }
        print(json.dumps(output, ensure_ascii=False, sort_keys=True))
        return 0 if output["taskVerified"] else 2
    except (SecretError, OSError, ValueError, UnicodeError, json.JSONDecodeError, subprocess.TimeoutExpired) as error:
        print(json.dumps({
            "schemaVersion": 1, "processCompleted": False, "taskVerified": False,
            "error": str(error), "message": "Secret operation stopped without exposing a plaintext value.",
        }, sort_keys=True), file=sys.stderr)
        return 2


if __name__ == "__main__":
    raise SystemExit(main())
