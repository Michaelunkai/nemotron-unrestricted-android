#!/data/data/com.termux/files/usr/bin/python
"""Deterministic headless HTTP browser with verified static-DOM actions."""

import argparse
import hashlib
import html
from html.parser import HTMLParser
import http.cookiejar
import json
import pathlib
import sys
import time
import urllib.error
import urllib.parse
import urllib.request

from nemotron_automation import safe_mode_status


class BrowserError(Exception):
    pass


class Element:
    def __init__(self, tag, attrs):
        self.tag = tag.lower()
        self.attrs = {str(key).lower(): str(value or "") for key, value in attrs}
        self.text = []

    def rendered_text(self):
        return " ".join("".join(self.text).split())


class Document(HTMLParser):
    def __init__(self, source):
        super().__init__(convert_charrefs=True)
        self.elements = []
        self.stack = []
        self.title = ""
        self._title_depth = 0
        self.feed(source)

    def handle_starttag(self, tag, attrs):
        element = Element(tag, attrs)
        self.elements.append(element)
        self.stack.append(element)
        if element.tag == "title":
            self._title_depth += 1

    def handle_startendtag(self, tag, attrs):
        self.elements.append(Element(tag, attrs))

    def handle_endtag(self, tag):
        tag = tag.lower()
        for index in range(len(self.stack) - 1, -1, -1):
            if self.stack[index].tag == tag:
                del self.stack[index:]
                break
        if tag == "title" and self._title_depth:
            self._title_depth -= 1

    def handle_data(self, data):
        for element in self.stack:
            element.text.append(data)
        if self._title_depth:
            self.title += data

    def body_text(self):
        body = next((item for item in self.elements if item.tag == "body"), None)
        source = body.rendered_text() if body else " ".join(item.rendered_text() for item in self.elements)
        return " ".join(source.split())


def safe_url(value):
    parsed = urllib.parse.urlparse(str(value or ""))
    if parsed.scheme not in {"http", "https"} or not parsed.hostname:
        raise BrowserError("url_invalid")
    if parsed.username or parsed.password:
        raise BrowserError("url_credentials_forbidden")
    return urllib.parse.urlunparse((parsed.scheme, parsed.netloc, parsed.path or "/", parsed.params, parsed.query, ""))


def selector_match(element, selector):
    selector = selector.strip()
    if not selector or any(token in selector for token in (" ", ">", "+", "~", ",", ":")):
        raise BrowserError("selector_not_supported")
    tag = None
    key = None
    value = None
    if selector.startswith("#"):
        key, value = "id", selector[1:]
    elif selector.startswith("."):
        key, value = "class", selector[1:]
    elif selector.startswith("[") and selector.endswith("]") and "=" in selector:
        key, value = selector[1:-1].split("=", 1)
        key = key.strip().lower()
        value = value.strip().strip("\"'")
    else:
        tag = selector.lower()
    if tag is not None:
        return element.tag == tag
    if key == "class":
        return value in element.attrs.get("class", "").split()
    return element.attrs.get(key) == value


class StaticBrowser:
    def __init__(self, timeout):
        jar = http.cookiejar.CookieJar()
        self.opener = urllib.request.build_opener(urllib.request.HTTPCookieProcessor(jar))
        self.timeout = timeout
        self.url = None
        self.status = None
        self.content_type = None
        self.source = None
        self.document = None
        self.fields = {}
        self.events = []

    def navigate(self, url, method="GET", data=None):
        requested = safe_url(url)
        encoded = None
        if data is not None:
            encoded = urllib.parse.urlencode(data).encode("utf-8")
        request = urllib.request.Request(
            requested, data=encoded, method=method,
            headers={"User-Agent": "NemotronVerifiedBrowser/1.0", "Accept": "text/html,application/xhtml+xml,*/*;q=0.8"},
        )
        try:
            with self.opener.open(request, timeout=self.timeout) as response:
                payload = response.read(4 * 1024 * 1024 + 1)
                if len(payload) > 4 * 1024 * 1024:
                    raise BrowserError("page_too_large")
                self.url = safe_url(response.geturl())
                self.status = response.status
                self.content_type = response.headers.get_content_type()
                charset = response.headers.get_content_charset() or "utf-8"
        except urllib.error.HTTPError as error:
            raise BrowserError(f"http_status_{error.code}") from error
        except urllib.error.URLError as error:
            raise BrowserError("network_error") from error
        if self.content_type not in {"text/html", "application/xhtml+xml"}:
            raise BrowserError("page_not_html")
        self.source = payload.decode(charset, "replace")
        self.document = Document(self.source)
        self.fields = {}
        self.events.append(f"Loaded {self.url} and verified HTTP {self.status}.")

    def find(self, selector):
        matches = [item for item in self.document.elements if selector_match(item, selector)]
        if not matches:
            raise BrowserError("selector_not_found")
        return matches[0]

    def wait(self, selector, timeout_ms):
        deadline = time.monotonic() + timeout_ms / 1000
        while True:
            try:
                self.find(selector)
                self.events.append(f"Verified that selector {selector} is present.")
                return
            except BrowserError as error:
                if str(error) != "selector_not_found":
                    raise
                if time.monotonic() >= deadline:
                    raise BrowserError("selector_wait_timeout")
                time.sleep(min(0.25, max(0, deadline - time.monotonic())))
                self.navigate(self.url)

    def fill(self, selector, value):
        element = self.find(selector)
        if element.tag not in {"input", "textarea", "select"}:
            raise BrowserError("selector_not_fillable")
        name = element.attrs.get("name")
        if not name:
            raise BrowserError("field_name_missing")
        self.fields[name] = str(value)
        self.events.append(f"Filled the field named {name}.")

    def click(self, selector):
        element = self.find(selector)
        href = element.attrs.get("href")
        if href:
            self.navigate(urllib.parse.urljoin(self.url, href))
            self.events.append(f"Followed the verified link selected by {selector}.")
            return
        if element.tag in {"button", "input"}:
            self.submit(selector)
            return
        raise BrowserError("selector_not_clickable")

    def submit(self, selector):
        trigger = self.find(selector)
        form_id = trigger.attrs.get("form")
        forms = [item for item in self.document.elements if item.tag == "form"]
        if form_id:
            forms = [item for item in forms if item.attrs.get("id") == form_id]
        if len(forms) != 1:
            raise BrowserError("form_scope_ambiguous")
        form = forms[0]
        values = {}
        for item in self.document.elements:
            if item.tag not in {"input", "textarea", "select"}:
                continue
            name = item.attrs.get("name")
            if not name or item.attrs.get("disabled") is not None:
                continue
            if item.attrs.get("type", "").lower() in {"submit", "button", "file", "reset"}:
                continue
            values[name] = self.fields.get(name, item.attrs.get("value", ""))
        values.update(self.fields)
        action = urllib.parse.urljoin(self.url, form.attrs.get("action") or self.url)
        method = form.attrs.get("method", "get").upper()
        if method == "GET":
            query = urllib.parse.urlencode(values)
            separator = "&" if urllib.parse.urlparse(action).query else "?"
            self.navigate(action + (separator + query if query else ""))
        elif method == "POST":
            self.navigate(action, method="POST", data=values)
        else:
            raise BrowserError("form_method_not_supported")
        self.events.append(f"Submitted one {method} form and verified the response.")

    def evaluate(self, expression):
        values = {
            "document.title": self.document.title.strip(),
            "document.body.innerText": self.document.body_text(),
            "location.href": self.url,
        }
        if expression not in values:
            raise BrowserError("evaluation_not_allowlisted")
        self.events.append(f"Evaluated the allowlisted expression {expression}.")
        return values[expression]

    def download(self, selector, destination, replace=False):
        element = self.find(selector)
        href = element.attrs.get("href")
        if not href:
            raise BrowserError("download_href_missing")
        url = safe_url(urllib.parse.urljoin(self.url, href))
        path = pathlib.Path(destination).expanduser().resolve()
        if path.exists() and not replace:
            raise BrowserError("download_destination_exists")
        path.parent.mkdir(parents=True, exist_ok=True)
        temporary = path.with_name(path.name + ".partial")
        request = urllib.request.Request(url, headers={"User-Agent": "NemotronVerifiedBrowser/1.0"})
        try:
            with self.opener.open(request, timeout=self.timeout) as response, temporary.open("wb") as stream:
                digest = hashlib.sha256()
                size = 0
                while True:
                    block = response.read(64 * 1024)
                    if not block:
                        break
                    size += len(block)
                    if size > 512 * 1024 * 1024:
                        raise BrowserError("download_too_large")
                    digest.update(block)
                    stream.write(block)
            temporary.replace(path)
        finally:
            if temporary.exists():
                temporary.unlink()
        self.events.append(f"Downloaded {size} bytes and verified the SHA-256 digest.")
        return {"path": str(path), "bytes": size, "sha256": digest.hexdigest(), "url": url}


def render_evidence(browser, destination, pdf=False):
    try:
        from PIL import Image, ImageDraw, ImageFont
    except ImportError as error:
        raise BrowserError("pillow_not_available") from error
    lines = [browser.document.title.strip(), browser.url, "", browser.document.body_text()]
    wrapped = []
    for value in lines:
        value = value or ""
        while len(value) > 100:
            cut = value.rfind(" ", 0, 100)
            cut = cut if cut > 20 else 100
            wrapped.append(value[:cut])
            value = value[cut:].lstrip()
        wrapped.append(value)
    wrapped = wrapped[:180]
    image = Image.new("RGB", (1200, max(800, 32 * len(wrapped) + 80)), "white")
    draw = ImageDraw.Draw(image)
    font = ImageFont.load_default(size=20)
    for index, line in enumerate(wrapped):
        draw.text((35, 35 + index * 30), line, fill="black", font=font)
    path = pathlib.Path(destination).expanduser().resolve()
    path.parent.mkdir(parents=True, exist_ok=True)
    image.save(path, "PDF" if pdf else "PNG")
    return {"path": str(path), "bytes": path.stat().st_size, "sha256": hashlib.sha256(path.read_bytes()).hexdigest()}


def main():
    parser = argparse.ArgumentParser(description="Run a verified static-DOM browser workflow without opening Android UI.")
    parser.add_argument("url")
    parser.add_argument("--actions", help="JSON file containing bounded browser action objects")
    parser.add_argument("--wait-selector")
    parser.add_argument("--expect-text")
    parser.add_argument("--eval", action="append", default=[])
    parser.add_argument("--screenshot")
    parser.add_argument("--pdf")
    parser.add_argument("--timeout", type=int, default=30)
    args = parser.parse_args()
    try:
        host = urllib.parse.urlparse(args.url).hostname
        if safe_mode_status()["active"] and host not in {"127.0.0.1", "localhost", "::1"}:
            raise BrowserError("local_only_safe_mode_active")
        if not 1 <= args.timeout <= 120:
            raise BrowserError("timeout_invalid")
        browser = StaticBrowser(args.timeout)
        browser.navigate(args.url)
        evaluations = {}
        downloads = []
        if args.actions:
            actions = json.loads(pathlib.Path(args.actions).read_text(encoding="utf-8"))
            if not isinstance(actions, list) or len(actions) > 50:
                raise BrowserError("actions_invalid")
            for action in actions:
                if not isinstance(action, dict) or set(action) - {"action", "selector", "value", "timeoutMs", "path", "replace"}:
                    raise BrowserError("action_schema_invalid")
                kind = action.get("action")
                if kind == "fill":
                    browser.fill(action.get("selector", ""), action.get("value", ""))
                elif kind == "click":
                    browser.click(action.get("selector", ""))
                elif kind == "submit":
                    browser.submit(action.get("selector", ""))
                elif kind == "wait":
                    browser.wait(action.get("selector", ""), int(action.get("timeoutMs", 5000)))
                elif kind == "download":
                    downloads.append(browser.download(action.get("selector", ""), action.get("path", ""), bool(action.get("replace"))))
                else:
                    raise BrowserError("action_unknown")
        if args.wait_selector:
            browser.wait(args.wait_selector, min(args.timeout * 1000, 30_000))
        if args.expect_text and args.expect_text not in browser.document.body_text():
            raise BrowserError("expected_text_missing")
        for expression in args.eval:
            evaluations[expression] = browser.evaluate(expression)
        screenshot = render_evidence(browser, args.screenshot) if args.screenshot else None
        pdf = render_evidence(browser, args.pdf, pdf=True) if args.pdf else None
        output = {
            "schemaVersion": 1, "processCompleted": True, "taskVerified": True,
            "backend": "static-http-dom", "javascriptExecuted": False,
            "url": browser.url, "status": browser.status, "title": browser.document.title.strip(),
            "evaluations": evaluations, "downloads": downloads,
            "screenshot": screenshot, "pdf": pdf, "events": browser.events,
            "limitation": "JavaScript-only interactions require an installed Chromium/CDP backend and are never reported as completed by this fallback.",
            "message": "The headless static-DOM browser completed every requested action and verified its postconditions.",
        }
        print(json.dumps(output, ensure_ascii=False, sort_keys=True))
        return 0
    except (BrowserError, OSError, ValueError, json.JSONDecodeError) as error:
        print(json.dumps({
            "schemaVersion": 1, "processCompleted": False, "taskVerified": False,
            "error": str(error), "message": "Browser automation stopped without claiming an unverified interaction.",
        }, sort_keys=True), file=sys.stderr)
        return 2


if __name__ == "__main__":
    raise SystemExit(main())
