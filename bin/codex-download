#!/data/data/com.termux/files/usr/bin/python
"""Confined download wrapper with isolated provenance and local readback."""

from __future__ import annotations

import argparse
import hashlib
import json
import os
import pathlib
import re
import subprocess
import sys
import urllib.parse
import uuid


PROJECT_ROOT = pathlib.Path(__file__).resolve().parents[1]
RUNTIME_ROOT = PROJECT_ROOT / "runtime" / ".codex"
ISOLATED_HOME = PROJECT_ROOT / "runtime" / "home"
GLOBAL_COMMAND = pathlib.Path("/data/data/com.termux/files/home/.local/bin/codex-download")
PROJECT_OUTPUT_ROOTS = (
    RUNTIME_ROOT / "downloads",
    PROJECT_ROOT / "workspace",
)
ANDROID_DOWNLOAD = pathlib.Path("/storage/emulated/0/Download")
SHA256_RE = re.compile(r"^[0-9a-fA-F]{64}$")


class DownloadPolicyError(ValueError):
    pass


def parser():
    result = argparse.ArgumentParser(
        prog="codex-download",
        usage=(
            "codex-download <url> [output] [--output path] [--sha256 digest] "
            "[--retries N] [--timeout N] [--max-bytes N]"
        ),
    )
    result.add_argument("url")
    result.add_argument("positional_output", nargs="?")
    result.add_argument("--output")
    result.add_argument("--sha256")
    result.add_argument("--retries", type=int, default=3)
    result.add_argument("--timeout", type=int, default=600)
    result.add_argument("--max-bytes", type=int, default=2 * 1024 * 1024 * 1024)
    return result


def is_within(path: pathlib.Path, root: pathlib.Path) -> bool:
    return path == root or root in path.parents


def safe_filename(url: str) -> str:
    leaf = pathlib.PurePosixPath(urllib.parse.urlparse(url).path).name
    leaf = re.sub(r"[^A-Za-z0-9._-]+", "-", leaf).strip(".-")
    if not leaf:
        leaf = "download.bin"
    stem, suffix = os.path.splitext(leaf)
    return f"{stem[:80]}-{uuid.uuid4().hex[:12]}{suffix[:20]}"


def canonical_output(raw: str | None, url: str) -> pathlib.Path:
    if raw is None:
        candidate = PROJECT_OUTPUT_ROOTS[0] / safe_filename(url)
    else:
        if not raw or "\x00" in raw or raw.startswith("~"):
            raise DownloadPolicyError("output_path")
        if raw == "/sdcard/Download":
            raw = str(ANDROID_DOWNLOAD)
        elif raw.startswith("/sdcard/Download/"):
            raw = str(ANDROID_DOWNLOAD) + raw[len("/sdcard/Download"):]
        candidate = pathlib.Path(os.path.abspath(raw))
    if candidate.name in {"", ".", ".."}:
        raise DownloadPolicyError("output_path")
    if any(part in {".", ".."} for part in candidate.parts):
        raise DownloadPolicyError("output_path")
    allowed_root = next(
        (root for root in (*PROJECT_OUTPUT_ROOTS, ANDROID_DOWNLOAD) if is_within(candidate, root)),
        None,
    )
    if allowed_root is None or candidate == allowed_root:
        raise DownloadPolicyError("output_outside_isolation")
    current = candidate.parent
    while is_within(current, allowed_root):
        if current.is_symlink():
            raise DownloadPolicyError("output_symlink")
        if current.exists() and not current.is_dir():
            raise DownloadPolicyError("output_parent")
        if current == allowed_root:
            break
        current = current.parent
    allowed_root.mkdir(parents=True, exist_ok=True, mode=0o700)
    candidate.parent.mkdir(parents=True, exist_ok=True, mode=0o700)
    if candidate.exists() or candidate.is_symlink():
        raise DownloadPolicyError("output_exists")
    parent_real = candidate.parent.resolve(strict=True)
    root_real = allowed_root.resolve(strict=True)
    if not is_within(parent_real, root_real):
        raise DownloadPolicyError("output_symlink")
    return candidate


def sha256_file(path: pathlib.Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as stream:
        for block in iter(lambda: stream.read(1024 * 1024), b""):
            digest.update(block)
    return digest.hexdigest()


def cleanup_failed_output(path: pathlib.Path):
    for candidate in (path, path.with_name(path.name + ".part")):
        try:
            if candidate.is_file() and not candidate.is_symlink():
                candidate.unlink()
        except OSError:
            pass


def main():
    args = parser().parse_args()
    destination = None
    try:
        parsed = urllib.parse.urlparse(args.url)
        if parsed.scheme not in {"http", "https"} or not parsed.hostname:
            raise DownloadPolicyError("url_scheme")
        if parsed.username is not None or parsed.password is not None:
            raise DownloadPolicyError("url_credentials")
        if args.positional_output and args.output:
            raise DownloadPolicyError("output_ambiguous")
        expected = args.sha256.lower() if args.sha256 else None
        if expected is not None and not SHA256_RE.fullmatch(expected):
            raise DownloadPolicyError("sha256_shape")
        if not 1 <= args.retries <= 8:
            raise DownloadPolicyError("retry_range")
        if not 1 <= args.timeout <= 3600:
            raise DownloadPolicyError("timeout_range")
        if not 1 <= args.max_bytes <= 2 * 1024 * 1024 * 1024:
            raise DownloadPolicyError("size_range")
        destination = canonical_output(args.output or args.positional_output, args.url)
        if not GLOBAL_COMMAND.is_file() or not os.access(GLOBAL_COMMAND, os.X_OK):
            raise DownloadPolicyError("download_backend_unavailable")
        command = [
            str(GLOBAL_COMMAND),
            args.url,
            "--output", str(destination),
            "--retries", str(args.retries),
            "--timeout", str(args.timeout),
            "--max-bytes", str(args.max_bytes),
        ]
        if expected:
            command.extend(("--sha256", expected))
        env = dict(
            os.environ,
            HOME=str(ISOLATED_HOME),
            CODEX_HOME=str(RUNTIME_ROOT),
            CODEX_RUNTIME_ROOT=str(RUNTIME_ROOT),
        )
        completed = subprocess.run(
            command,
            env=env,
            capture_output=True,
            text=True,
            timeout=min(7200, args.timeout * args.retries + 120),
            check=False,
        )
        try:
            receipt = json.loads(completed.stdout)
        except json.JSONDecodeError as error:
            raise DownloadPolicyError("backend_receipt") from error
        if completed.returncode != 0 or receipt.get("ok") is not True:
            raise DownloadPolicyError("download_failed")
        if not destination.is_file() or destination.is_symlink():
            raise DownloadPolicyError("output_missing")
        actual_size = destination.stat().st_size
        actual_hash = sha256_file(destination)
        receipt_output = pathlib.Path(str(receipt.get("output", "")))
        if receipt_output != destination:
            raise DownloadPolicyError("backend_output_mismatch")
        if receipt.get("sha256") != actual_hash or receipt.get("bytes") != actual_size:
            raise DownloadPolicyError("backend_readback_mismatch")
        if receipt.get("contentValidated") is not True:
            raise DownloadPolicyError("content_unverified")
        final_url = str((receipt.get("provenance") or {}).get("finalUrl") or "")
        final_parsed = urllib.parse.urlparse(final_url)
        if (
            final_parsed.scheme not in {"http", "https"}
            or not final_parsed.hostname
            or final_parsed.username is not None
            or final_parsed.password is not None
        ):
            raise DownloadPolicyError("redirect_unverified")
        if expected and actual_hash != expected:
            raise DownloadPolicyError("checksum_mismatch")
        print(
            json.dumps(
                {
                    "ok": True,
                    "output": str(destination),
                    "bytes": actual_size,
                    "sha256": actual_hash,
                    "sourceHost": parsed.hostname,
                    "finalHost": final_parsed.hostname,
                    "contentValidated": True,
                    "verified": True,
                },
                separators=(",", ":"),
                sort_keys=True,
            )
        )
        return 0
    except (DownloadPolicyError, OSError, subprocess.TimeoutExpired) as error:
        if destination is not None:
            cleanup_failed_output(destination)
        code = str(error) if isinstance(error, DownloadPolicyError) else "download_runtime_failure"
        print(json.dumps({"ok": False, "error": code, "verified": False}, separators=(",", ":")), file=sys.stderr)
        return 5


if __name__ == "__main__":
    raise SystemExit(main())
