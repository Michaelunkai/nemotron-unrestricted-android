#!/data/data/com.termux/files/usr/bin/python
"""Loopback-only secret-minimized Nemotron diagnostics dashboard."""

from __future__ import annotations

import argparse
import contextlib
import http.server
import json
import os
import pathlib
import signal
import subprocess
import sys
import threading
import time
import urllib.request

from nemotron_automation import AutomationState, DEFAULT_STATE, atomic_write


ROOT = pathlib.Path(__file__).resolve().parents[1]
PROCESS = DEFAULT_STATE / "dashboard.json"
SELF = pathlib.Path(__file__).resolve()


def process_matches(pid):
    try:
        command = pathlib.Path(f"/proc/{pid}/cmdline").read_bytes().replace(b"\0", b" ").decode(errors="replace")
    except OSError:
        return False
    return "codex-dashboard" in command and "serve" in command


def safe_events(state, maximum=50):
    if not state.log_path.is_file():
        return []
    rows = []
    for line in state.log_path.read_text(encoding="utf-8", errors="replace").splitlines()[-maximum:]:
        try:
            event = json.loads(line)
        except json.JSONDecodeError:
            continue
        fields = event.get("fields") if isinstance(event.get("fields"), dict) else {}
        rows.append({
            "timestamp": event.get("timestamp"),
            "level": event.get("level"),
            "module": event.get("module"),
            "message": event.get("message"),
            "correlationId": fields.get("correlationId"),
            "action": fields.get("action"),
            "latencyMs": fields.get("latencyMs"),
        })
    return rows


def inventory_summary(state):
    result = {}
    for key in ("gateway", "capabilities", "packages", "environment"):
        item = state.cache_get("inventory", key)
        value = item.get("value") if item else None
        count = None
        if key == "capabilities" and isinstance(value, dict):
            count = len(value.get("capabilities", []))
        elif key == "packages" and isinstance(value, list):
            count = len(value)
        result[key] = {
            "present": item is not None,
            "ageSeconds": item.get("ageSeconds") if item else None,
            "expiresAtEpoch": item.get("expiresAtEpoch") if item else None,
            "count": count,
        }
    return result


class Handler(http.server.BaseHTTPRequestHandler):
    server_version = "NemotronDiagnostics/1"

    def send_payload(self, status, content_type, payload):
        self.send_response(status)
        self.send_header("Content-Type", content_type)
        self.send_header("Cache-Control", "no-store")
        self.send_header("X-Content-Type-Options", "nosniff")
        self.send_header("Content-Security-Policy", "default-src 'none'; style-src 'unsafe-inline'")
        self.send_header("Content-Length", str(len(payload)))
        self.end_headers()
        if self.command != "HEAD":
            self.wfile.write(payload)

    def do_GET(self):
        state = AutomationState()
        if self.path == "/health":
            payload = json.dumps({
                "status": "ok", "service": "nemotron-diagnostics",
                "loopbackOnly": True, "secretFields": False,
            }, sort_keys=True).encode()
            self.send_payload(200, "application/json; charset=utf-8", payload)
            return
        if self.path == "/metrics":
            state.write_metrics()
            self.send_payload(200, "text/plain; version=0.0.4; charset=utf-8", state.metrics_path.read_bytes())
            return
        if self.path == "/events":
            self.send_payload(200, "application/json; charset=utf-8", json.dumps({"events": safe_events(state)}, sort_keys=True).encode())
            return
        if self.path == "/inventory":
            self.send_payload(200, "application/json; charset=utf-8", json.dumps({"inventories": inventory_summary(state)}, sort_keys=True).encode())
            return
        if self.path == "/":
            html = (
                "<!doctype html><meta charset=utf-8><title>Nemotron diagnostics</title>"
                "<style>body{font:16px system-ui;background:#0b0f12;color:#e8fff7;padding:2rem}"
                "a{color:#58e6b2}li{margin:.8rem 0}</style>"
                "<h1>Nemotron diagnostics</h1><p>Loopback-only, secret-minimized evidence.</p>"
                "<ul><li><a href=/health>Health</a></li><li><a href=/metrics>Metrics</a></li>"
                "<li><a href=/events>Recent events</a></li><li><a href=/inventory>Inventory freshness</a></li></ul>"
            ).encode()
            self.send_payload(200, "text/html; charset=utf-8", html)
            return
        self.send_payload(404, "application/json", b'{"error":"not_found"}')

    def do_HEAD(self):
        self.do_GET()

    def log_message(self, *_args):
        return


def serve(port):
    server = http.server.ThreadingHTTPServer(("127.0.0.1", port), Handler)
    server.daemon_threads = True
    server.serve_forever()


def main():
    parser = argparse.ArgumentParser(
        prog="codex-dashboard",
        description="Start, inspect, or stop the optional loopback-only diagnostics dashboard.",
    )
    commands = parser.add_subparsers(dest="command", required=True)
    start = commands.add_parser("start")
    start.add_argument("--port", type=int, default=18790)
    commands.add_parser("status")
    commands.add_parser("stop")
    hidden = commands.add_parser("serve")
    hidden.add_argument("--port", type=int, required=True)
    args = parser.parse_args()
    try:
        if args.command == "serve":
            serve(args.port)
            return 0
        if args.command == "status":
            record = json.loads(PROCESS.read_text()) if PROCESS.is_file() else {}
            pid = record.get("pid")
            running = isinstance(pid, int) and process_matches(pid)
            print(json.dumps({"schemaVersion": 1, "action": "Inspect the loopback diagnostics dashboard", "processCompleted": True, "taskVerified": True, "running": running, "pid": pid if running else None, "url": record.get("url") if running else None}, sort_keys=True))
            return 0
        if args.command == "start":
            if not 1024 <= args.port <= 65535:
                raise RuntimeError("port_invalid")
            if PROCESS.is_file():
                record = json.loads(PROCESS.read_text())
                if process_matches(record.get("pid")):
                    print(json.dumps({"schemaVersion": 1, "processCompleted": True, "taskVerified": True, "message": "The loopback dashboard is already running.", **record}, sort_keys=True))
                    return 0
            process = subprocess.Popen(
                [sys.executable, str(SELF), "serve", "--port", str(args.port)],
                cwd=ROOT, stdin=subprocess.DEVNULL, stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL, start_new_session=True,
            )
            url = f"http://127.0.0.1:{args.port}"
            for _ in range(30):
                try:
                    with urllib.request.urlopen(url + "/health", timeout=1) as response:
                        health = json.loads(response.read())
                    if health.get("status") == "ok" and health.get("loopbackOnly") is True:
                        break
                except Exception:
                    time.sleep(0.1)
            else:
                with contextlib.suppress(OSError):
                    os.kill(process.pid, signal.SIGTERM)
                raise RuntimeError("dashboard_readiness_failed")
            record = {"pid": process.pid, "port": args.port, "url": url, "bind": "127.0.0.1"}
            atomic_write(PROCESS, (json.dumps(record, sort_keys=True) + "\n").encode())
            print(json.dumps({"schemaVersion": 1, "action": "Start loopback-only diagnostics dashboard", "processCompleted": True, "taskVerified": True, **record}, sort_keys=True))
            return 0
        if not PROCESS.is_file():
            print(json.dumps({"schemaVersion": 1, "processCompleted": True, "taskVerified": True, "message": "The diagnostics dashboard was already stopped."}, sort_keys=True))
            return 0
        record = json.loads(PROCESS.read_text())
        pid = record.get("pid")
        if isinstance(pid, int) and process_matches(pid):
            os.kill(pid, signal.SIGTERM)
            for _ in range(30):
                if not process_matches(pid):
                    break
                time.sleep(0.1)
            if process_matches(pid):
                raise RuntimeError("dashboard_stop_timeout")
        PROCESS.unlink()
        print(json.dumps({"schemaVersion": 1, "action": "Stop exact loopback diagnostics dashboard", "processCompleted": True, "taskVerified": True, "stoppedPid": pid}, sort_keys=True))
        return 0
    except (OSError, RuntimeError, ValueError, json.JSONDecodeError) as error:
        print(json.dumps({"schemaVersion": 1, "processCompleted": False, "taskVerified": False, "error": str(error), "message": "Dashboard lifecycle stopped safely."}, sort_keys=True), file=sys.stderr)
        return 2


if __name__ == "__main__":
    raise SystemExit(main())
